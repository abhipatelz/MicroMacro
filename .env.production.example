# ── Copy this to Vercel → Settings → Environment Variables ──────────────────

# MongoDB Atlas connection string (get from Atlas → Connect → Drivers)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/pragati?retryWrites=true&w=majority

# Strong random secret — generate with: openssl rand -hex 32
JWT_SECRET=replace-with-64-char-random-string

# Email automatically promoted to the workspace admin role on first login
# (optional). Falls back to a hard-coded owner address if unset — see
# src/lib/auth.ts. There is one admin; everyone else is a lead or contributor.
ADMIN_EMAIL=you@company.com

# DO NOT set USE_IN_MEMORY_MONGO in production — leave it unset entirely.

# ── Flow Signal feature flags ───────────────────────────────────────────────
# Phase 0–3 (fact-based) is ON by default. The ML phases (4–8) stay OFF until
# explicitly enabled. See src/lib/flow/config.ts for the full set of knobs.
#
# Mode gates UI visibility:
#   off    — feature completely hidden
#   shadow — events recorded, no UI rendered
#   pilot  — UI shown only for teams in FLOW_SIGNAL_PILOT_TEAM_IDS
#   live   — UI shown everywhere
FLOW_SIGNAL_MODE=pilot
FLOW_SIGNAL_FACTS_ENABLED=true
FLOW_SIGNAL_ANOMALY_ENABLED=false
FLOW_SIGNAL_SURVIVAL_ENABLED=false
FLOW_SIGNAL_TEXT_CLASSIFIER_ENABLED=false
FLOW_SIGNAL_BANDIT_ENABLED=false
# CSV of team ids that see the strip during pilot mode. Empty = no UI surfaces.
FLOW_SIGNAL_PILOT_TEAM_IDS=
FLOW_SIGNAL_MODEL_CACHE_TTL_SECONDS=600
FLOW_SIGNAL_MAX_IC_PROMPTS_PER_DAY=3
FLOW_SIGNAL_MAX_LEAD_ITEMS=3
FLOW_SIGNAL_STILL_MOVING_COOLDOWN_HOURS=24
