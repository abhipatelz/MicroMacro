# ── Required ──────────────────────────────────────────────────────────────────

# MongoDB Atlas connection string (replace with your actual URI)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/pragati?retryWrites=true&w=majority

# Strong random secret — generate with: openssl rand -base64 48
JWT_SECRET=replace-me-with-a-long-random-secret

# ── Admin (single super-user) ────────────────────────────────────────────────
# Email that gets the 'admin' role automatically on login / registration.
# Admin sees every team, project, and user, and can reset anyone's password
# from the People page. Leave blank in dev if you don't want one.
ADMIN_EMAIL=

# ── First-run bootstrap (browser-only setup) ─────────────────────────────────
# When set to a long random string (>= 16 chars), the /bootstrap page becomes
# operative. Paste this token there, pick an admin email + password, and the
# account is provisioned + seed data is wiped — all without shell access.
# UNSET the variable + redeploy as soon as you're done; the endpoint then 404s.
# ADMIN_BOOTSTRAP_TOKEN=

# ── QA Copilot (optional) ─────────────────────────────────────────────────────
# Used only by the conversational Copilot. The QA Triage Assistant is
# rule-based and never uses an LLM — see CLAUDE.md.
GEMINI_API_KEY=

# ── Daily task-due email digest (optional) ────────────────────────────────────
# Powers the 08:30 IST "tasks due today" email. Delivery is via Brevo's free
# transactional HTTP API (no SMTP, no extra dependency). When BREVO_API_KEY and
# BREVO_SENDER_EMAIL are BOTH set, emails are sent; otherwise the mailer is a
# transparent no-op (nothing is sent, nothing breaks). The per-user opt-in lives
# in each profile and defaults OFF; the admin tunes content from Settings.
#   1. Create a free Brevo account → SMTP & API → API Keys → generate a key.
#   2. Verify a sender address (Senders & IP) and put it in BREVO_SENDER_EMAIL.
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=Pragati

# Secret shared with Vercel Cron. Vercel attaches it as a Bearer token on the
# scheduled call; the digest route refuses to run without it in production, so
# the endpoint can never be triggered anonymously. Generate with:
#   openssl rand -hex 32
CRON_SECRET=

# Absolute base URL of the deployment, used to build links inside the email
# (e.g. https://pragati.example.com). On Vercel this falls back to
# VERCEL_PROJECT_PRODUCTION_URL automatically; set it explicitly for a custom
# domain. When unset, emails are still sent but without clickable links.
APP_URL=

# Timezone used to compute "today" and the 08:30 send (default Asia/Kolkata).
# DIGEST_TZ=Asia/Kolkata

# ── Redis cache (optional) ────────────────────────────────────────────────────
# Upstash Redis REST credentials. When BOTH are set, hot read-only aggregations
# (e.g. the lead dashboard rollup) are served read-through from Redis with a
# short TTL; when either is missing the cache layer is a transparent no-op and
# every read goes straight to MongoDB (see src/lib/cache.ts). Never caches GxP
# records, audit entries, e-signatures, or the deterministic triage path.
# Get these from the Upstash console → your database → "REST API".
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Session micro-cache (scaling lever, default off — see docs/SCALING.md).
# When set (ms, max 60000), each instance caches session-validation reads for
# this long. Cuts the hottest DB path; tradeoff: a force-logout/deactivation
# can take up to this long to bite on other instances. 0/unset = strict
# read-every-request semantics.
SESSION_CACHE_TTL_MS=

# ── Development only (remove in production) ───────────────────────────────────
# Set true to run an embedded in-memory MongoDB instead of Atlas.
# USE_IN_MEMORY_MONGO=true
